# ── Server ──────────────────────────────────────────────
PORT=8080
BANKROLL=5000

# ── Engine Tuning ────────────────────────────────────────
STALE_MS=5000        # drop odds older than N ms
DELAY_MS=2000        # SHARP move within N ms = HIGH PRIORITY
MIN_ARB=0            # minimum arb % to emit (0 = all)

# ── Pinnacle ─────────────────────────────────────────────
PINNACLE_ENABLED=true
PINNACLE_SPORTS=soccer,basketball
PINNACLE_POLL_MS=3000
# Comma-separated league IDs to follow (empty = top 10 per sport)
PINNACLE_LEAGUE_IDS=

# ── The Odds API ─────────────────────────────────────────
# Get a free key at https://the-odds-api.com (500 requests/month free)
ODDS_API_KEY=YOUR_KEY_HERE
ODDS_API_ENABLED=true
ODDS_API_SPORTS=soccer,basketball
ODDS_API_POLL_MS=15000
ODDS_API_REGIONS=uk,eu
ODDS_API_MARKETS=h2h,spreads,totals
# Only include these bookmakers (comma-sep). Empty = all.
ODDS_API_BOOKMAKERS=

# ── SABA ─────────────────────────────────────────────────
SABA_ENABLED=false
SABA_ENDPOINT_URL=https://your-saba-member-site.com/api/odds
SABA_AUTH_HEADER=Bearer YOUR_TOKEN_HERE
SABA_POLL_MS=2000
